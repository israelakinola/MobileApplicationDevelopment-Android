<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_manager.xml
    PURPOSE: Layout for the Manager Panel screen.
    Simple two-button screen: HISTORY opens the purchase history list,
    RESTOCK opens the inventory restock screen.
    Both buttons are centered horizontally and stacked vertically in the middle
    of the screen with a gap between them.
    USED BY: ManagerActivity
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- HISTORY button: horizontally centered, sits just above vertical center -->
    <Button
        android:id="@+id/btnHistory"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_history"
        android:textSize="18sp"
        android:backgroundTint="@color/colorPrimary"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnRestock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- RESTOCK button: horizontally centered, sits just below HISTORY with 24dp gap -->
    <Button
        android:id="@+id/btnRestock"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="@string/btn_restock"
        android:textSize="18sp"
        android:backgroundTint="@color/colorAccent"
        android:textColor="@color/white"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnHistory"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
