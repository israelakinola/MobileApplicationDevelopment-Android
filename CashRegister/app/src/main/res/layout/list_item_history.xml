<?xml version="1.0" encoding="utf-8"?>
<!--
    list_item_history.xml
    PURPOSE: Row layout for a single purchase record in the RecyclerView shown
             in HistoryActivity.
    VIEWS:
      - tvProductName: name of the purchased product, large text, left-aligned
      - tvQuantity:    quantity bought, smaller muted text, below tvProductName
      - tvTotalPrice:  total price of the purchase, right-aligned and vertically centered
    USED BY: HistoryAdapter.onCreateViewHolder() / onBindViewHolder()
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <!-- Product name — primary label, left-aligned, constrained away from tvTotalPrice -->
    <TextView
        android:id="@+id/tvProductName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvTotalPrice"
        android:layout_marginEnd="8dp" />

    <!-- Quantity bought — secondary label, muted color, sits directly below tvProductName -->
    <TextView
        android:id="@+id/tvQuantity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/colorTextSecondary"
        app:layout_constraintTop_toBottomOf="@id/tvProductName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tvTotalPrice"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="8dp" />

    <!-- Total price — right-aligned, vertically centered across both name and quantity rows -->
    <TextView
        android:id="@+id/tvTotalPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/colorTextSecondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
