<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_history.xml
    PURPOSE: Layout for the Purchase History screen.
    Contains a single RecyclerView that fills the entire screen below the ActionBar.
    Each row is inflated from list_item_history.xml by HistoryAdapter.
    Tapping a row fires the OnItemClickListener set in HistoryActivity,
    which navigates to HistoryDetailActivity with the selected PurchaseHistory object.
    USED BY: HistoryActivity
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- RecyclerView: fills the full screen.
         Vertical LinearLayoutManager is set programmatically in HistoryActivity. -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewHistory"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
