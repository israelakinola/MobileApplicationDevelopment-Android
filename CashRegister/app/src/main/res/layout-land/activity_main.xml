<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml  (landscape — res/layout-land/)
    PURPOSE: Landscape variant of the main cash register screen.
    Android automatically picks this file over res/layout/activity_main.xml
    whenever the device is in landscape orientation.
    ALL VIEW IDs ARE IDENTICAL to the portrait layout so MainActivity.java
    needs zero orientation-specific code — the same findViewById() calls work
    for both orientations.

    LAYOUT (two-column):
      LEFT column  (start -> vertical guideline at 62%):
        - TableLayout numpad: anchored to bottom-left of left column
        - BUY button: right of numpad, spans its full height
      RIGHT column (vertical guideline -> end):
        - MANAGER button: top-right corner
        - ListView: fills right column from top to above the info TextViews
        - tvSelectedProduct: above tvQuantity/tvTotal
        - tvQuantity (left) / tvTotal (right): bottom of right column
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <!-- Vertical guideline at 62% width — divides numpad (left) from product area (right) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.62" />

    <!-- ===================== LEFT COLUMN — numpad + BUY ===================== -->

    <!-- Numpad TableLayout: anchored to the bottom-left of the left column.
         stretchColumns="*" equalizes the three digit columns. -->
    <TableLayout
        android:id="@+id/tableNumpad"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:stretchColumns="*"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnBuy">

        <TableRow android:layout_width="match_parent">
            <Button android:id="@+id/btn1" android:text="1"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp" />
            <Button android:id="@+id/btn2" android:text="2"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp" />
            <Button android:id="@+id/btn3" android:text="3"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp" />
        </TableRow>

        <TableRow android:layout_width="match_parent">
            <Button android:id="@+id/btn4" android:text="4"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp" />
            <Button android:id="@+id/btn5" android:text="5"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp" />
            <Button android:id="@+id/btn6" android:text="6"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp" />
        </TableRow>

        <TableRow android:layout_width="match_parent">
            <Button android:id="@+id/btn7" android:text="7"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp" />
            <Button android:id="@+id/btn8" android:text="8"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp" />
            <Button android:id="@+id/btn9" android:text="9"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp" />
        </TableRow>

        <!-- Bottom row: C (1 col) + 0 (spans 2 cols) -->
        <TableRow android:layout_width="match_parent">
            <Button android:id="@+id/btnClear" android:text="@string/btn_clear"
                android:backgroundTint="@color/colorAccent"
                android:textColor="@color/white" android:textSize="18sp" />
            <Button android:id="@+id/btn0" android:text="0"
                android:backgroundTint="@color/colorNumpad"
                android:textColor="@color/colorNumpadText" android:textSize="18sp"
                android:layout_span="2" />
        </TableRow>

    </TableLayout>

    <!-- BUY button: immediately right of numpad, spans numpad's full height,
         and is bounded on the right by the vertical guideline. -->
    <Button
        android:id="@+id/btnBuy"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="@string/btn_buy"
        android:backgroundTint="@color/colorPrimary"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/tableNumpad"
        app:layout_constraintBottom_toBottomOf="@id/tableNumpad"
        app:layout_constraintStart_toEndOf="@id/tableNumpad"
        app:layout_constraintEnd_toStartOf="@id/guidelineVertical" />

    <!-- ===================== RIGHT COLUMN — product list + info ===================== -->

    <!-- MANAGER button: top-right corner of the right column -->
    <Button
        android:id="@+id/btnManager"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_manager"
        android:backgroundTint="@color/colorAccent"
        android:textColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Product ListView: fills the right column from below MANAGER down to tvSelectedProduct -->
    <ListView
        android:id="@+id/listViewProducts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:divider="@android:color/darker_gray"
        android:dividerHeight="1dp"
        app:layout_constraintTop_toBottomOf="@id/btnManager"
        app:layout_constraintStart_toEndOf="@id/guidelineVertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvSelectedProduct"
        android:layout_marginStart="8dp" />

    <!-- Selected product name: above the quantity/total row in the right column -->
    <TextView
        android:id="@+id/tvSelectedProduct"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_select_product"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:padding="4dp"
        app:layout_constraintStart_toEndOf="@id/guidelineVertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvQuantity"
        android:layout_marginStart="8dp" />

    <!-- Quantity display: bottom-left of right column -->
    <TextView
        android:id="@+id/tvQuantity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_quantity"
        android:textSize="15sp"
        android:padding="4dp"
        app:layout_constraintStart_toEndOf="@id/guidelineVertical"
        app:layout_constraintEnd_toStartOf="@id/tvTotal"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="8dp" />

    <!-- Total display: bottom-right of right column -->
    <TextView
        android:id="@+id/tvTotal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_total"
        android:textSize="15sp"
        android:textAlignment="textEnd"
        android:padding="4dp"
        app:layout_constraintStart_toEndOf="@id/tvQuantity"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
